{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run C",
      "type": "shell",
      "command": "gcc *.c -o main.exe; if ($?) { .\\main.exe }",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}